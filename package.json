{
  "name": "wektodo",
  "version": "1.0.0",
  "description": "A simple Electron todo app with SQLite storage.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.wektodo.app",
    "productName": "WekToDo",
      "extraResources": [
    {
      "from": "icon.ico",
      "to": "icon.ico"
    }
  ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "db.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
    
  }
}